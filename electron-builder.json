{
  "appId": "com.dfapro.app",
  "productName": "DFA Pro",
  "directories": {
    "output": "release"
  },
  "files": [
    "electron/**/*",
    "dist/**/*",
    "server/**/*",
    "!server/node_modules",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "server",
      "to": "server",
      "filter": ["**/*", "!node_modules"]
    },
    {
      "from": "dist",
      "to": "dist",
      "filter": ["**/*"]
    }
  ],
  "asar": true,
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "electron/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "DFA Pro",
    "installerIcon": "electron/icon.png",
    "uninstallerIcon": "electron/icon.png",
    "artifactName": "DFA-Pro-Setup-${version}.${ext}"
  },
  "mac": {
    "target": [
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ],
    "icon": "electron/icon.png",
    "category": "public.app-category.finance",
    "artifactName": "DFA-Pro-${version}-mac.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "icon": "electron/icon.png",
    "category": "Finance",
    "artifactName": "DFA-Pro-${version}.${ext}"
  },
  "publish": null
}
